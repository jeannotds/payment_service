# Copier vers .env : cp .env.example .env
# Local / Prisma CLI : port hôte 5433 → conteneur Postgres 5432
DATABASE_URL=postgresql://postgres:password@localhost:5433/payments

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=payments

REDIS_HOST=redis

JWT_SECRET=superSecretKey123
JWT_EXPIRES_IN=1d
